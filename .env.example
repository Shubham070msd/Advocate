# Copy this file to ".env" and fill in your key.
# The CLI auto-loads .env (see load_dotenv in cli.py).

# ---- Default: OpenAI / GPT ----
ADVOCATE_LLM_PROVIDER=openai
ADVOCATE_LLM_API_KEY=sk-your-openai-key-here
ADVOCATE_LLM_MODEL=gpt-4o-mini

# ---- Using a different LLM? Just change the three vars above. ----
# Groq (OpenAI-compatible, free tier):
#   ADVOCATE_LLM_PROVIDER=groq
#   ADVOCATE_LLM_API_KEY=gsk_...
#   ADVOCATE_LLM_MODEL=llama-3.3-70b-versatile
#
# DeepSeek (OpenAI-compatible):
#   ADVOCATE_LLM_PROVIDER=deepseek
#   ADVOCATE_LLM_API_KEY=sk-...
#   ADVOCATE_LLM_MODEL=deepseek-chat
#
# Ollama (local, free, no key — run `ollama serve` first):
#   ADVOCATE_LLM_PROVIDER=ollama
#   ADVOCATE_LLM_MODEL=llama3.1
#
# Anthropic Claude (uses the built-in adapter):
#   ADVOCATE_LLM_PROVIDER=anthropic
#   ADVOCATE_LLM_API_KEY=sk-ant-...
#   ADVOCATE_LLM_MODEL=claude-sonnet-4-6
